{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/SamyRai/tatar-names/schemas/attestations.schema.json",
  "title": "Tatar Names source attestations.csv row",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "attestation_id",
    "entity_id",
    "form",
    "script",
    "language_tag",
    "form_kind",
    "profile",
    "is_canonical",
    "confidence",
    "source_id",
    "evidence_id"
  ],
  "properties": {
    "attestation_id": { "type": "string", "pattern": "^at_[0-9]{7}$" },
    "entity_id": { "type": "string", "pattern": "^ttn_[0-9]{6}$" },
    "form": { "type": "string", "minLength": 1 },
    "script": { "type": "string", "enum": ["Cyrl", "Latn"] },
    "language_tag": { "type": "string", "minLength": 1 },
    "form_kind": { "type": "string", "enum": ["canonical", "observed_variant", "transliterated", "normalized_source"] },
    "profile": {
      "type": "string",
      "enum": [
        "ru_adaptation",
        "tt_original",
        "tt_cyrl_to_tt_latn_rt2013",
        "ru_cyrl_to_latn_mvd_doc",
        "common_variant"
      ]
    },
    "is_canonical": { "type": "string", "enum": ["true", "false"] },
    "confidence": { "type": "string", "pattern": "^(0(\\.\\d+)?|1(\\.0+)?)$" },
    "source_id": { "type": "string", "minLength": 1 },
    "evidence_id": { "type": "string" }
  }
}
