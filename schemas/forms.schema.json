{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/SamyRai/tatar-names/schemas/forms.schema.json",
  "title": "Tatar Names forms.csv row",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "form_id",
    "name_id",
    "form",
    "script",
    "language_tag",
    "form_role",
    "identity_status",
    "profile",
    "confidence",
    "source_id",
    "evidence_id",
    "merge_policy"
  ],
  "properties": {
    "form_id": { "type": "string", "pattern": "^f_[0-9]{7}$" },
    "name_id": { "type": "string", "pattern": "^ttn_[0-9]{6}$" },
    "form": { "type": "string", "minLength": 1 },
    "script": { "type": "string", "enum": ["Cyrl", "Latn"] },
    "language_tag": { "type": "string", "minLength": 1 },
    "form_role": {
      "type": "string",
      "enum": [
        "official_tt",
        "official_ru_or_russified_primary",
        "tt_latin_transliteration",
        "passport_latin",
        "common_observed"
      ]
    },
    "identity_status": { "type": "string", "enum": ["canonical", "variant", "alias"] },
    "profile": {
      "type": "string",
      "enum": [
        "ru_adaptation",
        "tt_original",
        "tt_cyrl_to_tt_latn_rt2013",
        "ru_cyrl_to_latn_mvd_doc",
        "common_variant"
      ]
    },
    "confidence": { "type": "string", "pattern": "^(0(\\.\\d+)?|1(\\.0+)?)$" },
    "source_id": { "type": "string", "minLength": 1 },
    "evidence_id": { "type": "string" },
    "merge_policy": {
      "type": "string",
      "enum": ["auto_merge", "candidate_only", "never_merge", "review_required"]
    }
  }
}
